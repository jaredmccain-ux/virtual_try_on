// =============================================================================
// 字段含义速查（注释区，不参与 JSON 解析）
// =============================================================================
//
// --- 顶层 ---
// sample_id            [脚本] 全局样本 ID（paired=source_sample_id；unpair=unpair_xxx__garment_yyy）
// source_sample_id     [脚本] paired 原始 ID；unpair 可无
// pair_mode            [脚本] paired | unpair
// scene_id             [脚本] A B C D E L1 L2 L3 I1 I2（F=无效，不会产出）
// person_upper_state   [脚本] U0 | U1 | U2 | whole
// garment_class        [脚本] G0 非外套 | G1 外套（C 场景 paired 强制显示 G0）
// person_image         [脚本] 模特图路径
// garment_image        [脚本] 衣物图路径
// provider/model       [脚本] 标注来源
// review_verdict       [人工] 审核结论
// supplement_meta      [脚本] 补标记录（gender / embellishment / have_inner）
// postprocess_meta     [脚本] 后处理记录
// person_anchor_id     [脚本] unpair 人物 anchor ID
// garment_donor_id     [脚本] unpair 衣物 donor ID
// paired_baseline_id   [脚本] unpair 对应 anchor 的 paired baseline ID
// active_region        [脚本] upper_body_garment | lower_body_garment | whole_body_garment
//
// --- annotation.person ---
// role                 [模型] male | female
// wearing_type         [模型] one_piece | two_pieces
// is_present           [模型] 区域是否穿着
// category             [模型] 品类
// fit                  [模型] tight | regular | loose | oversized
// tucking_style        [模型] untucked | fully_tucked_in | french_tucked | half_tuck
// sleeve_state         [模型] sleeves_down | rolled_up_sleeves
// pants_cuff_state     [模型] normal_pants_cuff | rolled_up_pants
// neckline             [模型] round | v-neck | square_neck | turtleneck | off-shoulder | hood
// sleeve_length        [模型] sleeveless | short_sleeve | 3/4_sleeve | long_sleeve
// sleeve_type          [模型] regular | puff_sleeve | bell_sleeve | raglan
// collar_type          [模型] lapel_collar | stand_collar | shirt_collar | not_applicable
// hem_length           [模型] mini | knee-length | midi | maxi | full-length | cropped
// hem_shape            [模型] straight_hem | asymmetric_hem | curved_hem | slit
// color/pattern/...    [模型] 见 edit_value_enums.json
// embellishment        [模型·补标] none | button_detail | pleat | ruffle | bow | lace_trim |
//                               embroidery | sequin | fringe | distressed | zipper_detail | cutout
// outer_closure        [模型] not_applicable | open | closed
// is_outerwear         [模型] true | false
// have_inner           [模型·补标] true | false | not_applicable（仅 person 上装为外套时有意义）
// is_paired            [脚本] unpair 重建时标记哪块是 active_region
//
// --- annotation.garment ---
// gender               [模型·补标] male | female
// where_to_dress       [模型] upper_body | lower_body | whole_body
//
// --- edit / instruction ---
// edit_type_id         [脚本] E01-E08, E09-E20（每套 target=10，共 200 条/套）
// edit_spec            [脚本] 本条 edit（5 维度，含 from/to）
// changes_by_dimension [脚本] 同 edit_spec
// preserved_by_dimension [脚本] 需 preserve 的结构化值（JSON 存值；prompt 写「不变」）
// instruction_spec     [脚本] scene_id + base_task + edit + preserve 结构化块
// instruction_en/zh    [脚本] FireRed prompt（含 scene base + edit 指代前缀）
// template_version     [脚本] edit_instruction_v3_scene
//
// --- 场景 base_task 含义 ---
// A  换上装（U0 + G0）
// B  换下装
// C  换连体
// D  上下装→换连体
// E  连体上叠外套
// L1 叠外套（保留内搭）
// L2 换外套
// L3 上装换成外套（不保留原内搭）
// I1 只换内搭（保留外套）
// I2 去外套，换上装
